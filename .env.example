# ===== מסד נתונים (פיתוח מקומי / Docker) =====
DB_USER=tiferet
DB_PASSWORD=tiferet
DB_NAME=tiferet
DB_PORT=5432

# ===== מסד נתונים מנוהל בענן (Supabase וכו') — ייצור =====
# כשמוגדר DATABASE_URL הבקאנד מתחבר אליו (עם SSL) ומתעלם ממשתני DB_* שלמעלה.
# חשוב: השתמשו במחרוזת ה-Session Pooler (IPv4) של Supabase, לא בחיבור הישיר (IPv6).
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ===== בקאנד =====
BACKEND_PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# ===== פרונטאנד =====
FRONTEND_PORT=8080
